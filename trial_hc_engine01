# app.py
from flask import Flask, render_template, request, redirect, url_for, session
from datetime import datetime, timedelta

app = Flask(__name__)
app.secret_key = "change-me"

# demo users
USERS = {"alice": "1234", "bob": "abcd"}

# 5x6 seats, store as dict: "A1" -> username or None
SEATS = {f"{r}{c}": None for r in "ABCDE" for c in range(1, 7)}

# reservations: username -> {"seat": "A1", "time": datetime, "remind": "1h"/"1d"}
RESERVATIONS = {}

@app.route("/", methods=["GET", "POST"])
def login():
    if request.method == "POST":
        user = request.form["username"]
        pw = request.form["password"]
        if user in USERS and USERS[user] == pw:
            session["user"] = user
            return redirect(url_for("reserve"))
        return "Login failed"
    return render_template("login.html")

@app.route("/reserve", methods=["GET", "POST"])
def reserve():
    if "user" not in session:
        return redirect(url_for("login"))
    user = session["user"]

    if request.method == "POST":
        seat_id = request.form["seat"]
        remind = request.form["remind"]  # "1h" or "1d"

        # simple rule: reservation time = now + 2 hours (for demo)
        start_time = datetime.now() + timedelta(hours=2)

        # check if seat free
        if SEATS.get(seat_id) is None:
            SEATS[seat_id] = user
            RESERVATIONS[user] = {
                "seat": seat_id,
                "time": start_time,
                "remind": remind,
            }
            return f"Reserved {seat_id} with reminder {remind}"
        else:
            return "Seat already taken"

    # build 5x6 grid as list of rows; each row is list of (seat_id, taken_bool)
    rows = []
    row_names = "ABCDE"
    idx = 0
    for r in row_names:
        row = []
        for c in range(1, 7):
            sid = f"{r}{c}"
            row.append((sid, SEATS[sid] is not None))
            idx += 1
        rows.append(row)
    return render_template("seats.html", rows=rows, user=user)

# very simple “checker” to show when reminders should fire
@app.route("/check_reminders")
def check_reminders():
    now = datetime.now()
    msgs = []
    for u, r in RESERVATIONS.items():
        if r["remind"] == "1h":
            remind_at = r["time"] - timedelta(hours=1)
        else:
            remind_at = r["time"] - timedelta(days=1)
        if remind_at <= now <= remind_at + timedelta(minutes=1):
            msgs.append(f"Send reminder to {u} for seat {r['seat']}")
    return "<br>".join(msgs) or "No reminders now"

if __name__ == "__main__":
    app.run(debug=True)
